body {
    font-family: Arial, sans-serif;
    margin: 20px;
    background-color: #f4f4f4;
}

h1 {
    color: green;
}

form {
    background: white;
    padding: 20px;
    border-radius: 10px;
}

input,
textarea {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
}

button {
    background: green;
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
}

button:hover {
    opacity: 0.9;
}

li {
    background: white;
    padding: 10px;
    margin-top: 10px;
    border-radius: 5px;
}
